{
  "name": "@amazon-q-developer/ui-components",
  "version": "1.0.0",
  "description": "A comprehensive UI components library built with React, TypeScript, and TailwindCSS",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite serve playground",
    "build": "npm run build:lib && npm run build:playground",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:playground": "vite build --config vite.playground.config.ts",
    "preview": "vite preview --config vite.playground.config.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src playground --ext .ts,.tsx",
    "lint:fix": "eslint src playground --ext .ts,.tsx --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "prepare": "npm run build:lib"
  },
  "keywords": [
    "react",
    "typescript",
    "tailwindcss",
    "ui-components",
    "component-library"
  ],
  "author": "Amazon Q Developer",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-dts": "^3.6.4",
    "vitest": "^1.0.4"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "lucide-react": "^0.294.0"
  }
}